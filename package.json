{
  "name": "sparcoon",
  "version": "0.6.0",
  "description": "Instanced-mesh particle system for Three.js.",
  "keywords": [
    "particles",
    "particle-system",
    "three.js",
    "3d",
    "webgl",
    "instanced",
    "billboard",
    "typescript"
  ],
  "author": "jango",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jango-git/sparcoon.git"
  },
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && rollup -c",
    "prepublishOnly": "npm run build"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "peerDependencies": {
    "fast-simplex-noise": "^4.0.0",
    "ferrsign": "^0.0.4",
    "three": ">=0.157.0 <0.180.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@types/node": "^25.0.2",
    "@types/three": "^0.157.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^9.26.0",
    "rollup": "^4.40.2",
    "rollup-plugin-string": "^3.0.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "ts-transformer-minify-privates": "^1.0.0",
    "typescript": "^5.8.3"
  }
}
